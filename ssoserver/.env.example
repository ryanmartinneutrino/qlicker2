# Local SimpleSAMLphp test IdP
SSOSERVER_PORT=4100
SSOSERVER_BASE_URL=http://127.0.0.1:4100
SSOSERVER_BASE_PATH=simplesaml
SSOSERVER_ENTITY_ID=http://127.0.0.1:4100/simplesaml/saml2/idp/metadata.php
SSOSERVER_ENTRYPOINT_URL=http://127.0.0.1:4100/simplesaml/module.php/saml/idp/singleSignOnService
SSOSERVER_LOGOUT_URL=http://127.0.0.1:4100/simplesaml/module.php/saml/idp/singleLogout
SSOSERVER_INSTITUTION_NAME="Local SimpleSAMLphp"
SSOSERVER_ADMIN_PASSWORD=changeme-admin-password
SSOSERVER_SECRET_SALT=replace-with-a-random-32-byte-string

# Qlicker app under test
# If these stay at the example defaults, the helper scripts will automatically
# prefer the repo root .env values (ROOT_URL / APP_PORT and VITE_API_URL / API_PORT)
# when they are present.
QCLICKER_APP_URL=http://127.0.0.1:3300
QCLICKER_API_URL=http://127.0.0.1:3301/api/v1
QCLICKER_SP_ENTITY_ID=http://127.0.0.1:3300/SSO/SAML2/metadata

# Seeded IdP users
SSO_PROFESSOR_USERNAME=sso-professor
SSO_PROFESSOR_PASSWORD=Password123!
SSO_PROFESSOR_EMAIL=sso-professor@example.com
SSO_PROFESSOR_FIRSTNAME=SSO
SSO_PROFESSOR_LASTNAME=Professor
SSO_PROFESSOR_ROLE=professor
SSO_PROFESSOR_STUDENT_NUMBER=900000001

SSO_STUDENT_USERNAME=sso-student
SSO_STUDENT_PASSWORD=Password123!
SSO_STUDENT_EMAIL=sso-student@example.com
SSO_STUDENT_FIRSTNAME=SSO
SSO_STUDENT_LASTNAME=Student
SSO_STUDENT_ROLE=student
SSO_STUDENT_STUDENT_NUMBER=900000002
