# =============================================================================
# Qlicker Production Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the values.
# Run ./setup.sh for an interactive setup that generates this file.
# =============================================================================

# --- Domain & TLS -----------------------------------------------------------
# The fully qualified domain name for your Qlicker instance.
DOMAIN=qlicker.example.com

# Paths to TLS certificate and private key (PEM format).
# Mount these into the nginx container via the docker-compose volume mapping.
# setup.sh --init-certs writes Let's Encrypt certs into ./certs/.
TLS_CERT_PATH=./certs/fullchain.pem
TLS_KEY_PATH=./certs/privkey.pem
# Set true to run certbot auto-renew checks in the certbot container.
CERTBOT_AUTORENEW=false

# Optional image overrides for the app services.
SERVER_IMAGE=qlicker/qlicker-server:latest
CLIENT_IMAGE=qlicker/qlicker-client:latest
# Runtime version string surfaced by /api/v1/health and the web UI.
APP_VERSION=v2.0.0.b1

# --- Scaling -----------------------------------------------------------------
# Number of API server replicas for load balancing.
# Recommended: 2–4 for most deployments (each handles ~500 concurrent WS).
SERVER_REPLICAS=2

# --- Secrets -----------------------------------------------------------------
# REQUIRED in production. Generate with: openssl rand -hex 32
JWT_SECRET=
JWT_REFRESH_SECRET=

# --- Database ----------------------------------------------------------------
# Built-in MongoDB admin credentials (required when using the bundled mongo service).
MONGO_INITDB_ROOT_USERNAME=qlickerAdmin
MONGO_INITDB_ROOT_PASSWORD=
# Internal MongoDB URI used by the server containers.
# Keep this in sync with the MongoDB admin credentials above.
# Example: mongodb://qlickerAdmin:<password>@mongo:27017/qlicker?authSource=admin
MONGO_URI=
# Conservative Mongo cache default for smaller hosts; increase on larger boxes.
MONGO_WIREDTIGER_CACHE_SIZE_GB=0.25
# App-side Mongo connection tuning for bursty live-session traffic.
MONGO_MAX_POOL_SIZE=25
MONGO_MIN_POOL_SIZE=0
MONGO_SERVER_SELECTION_TIMEOUT_MS=10000
MONGO_SOCKET_TIMEOUT_MS=45000
MONGO_CONNECT_RETRIES=6
MONGO_CONNECT_RETRY_DELAY_MS=2000

# --- Email -------------------------------------------------------------------
# SMTP URL for email verification and password reset.
# Format: smtp://user:password@smtp.example.com:587
MAIL_URL=

# --- Storage -----------------------------------------------------------------
# Options: local | s3 | azure
STORAGE_TYPE=local

# S3 / S3-compatible (MinIO) settings (only when STORAGE_TYPE=s3)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_BUCKET=
AWS_REGION=us-east-1
AWS_ENDPOINT=
AWS_FORCE_PATH_STYLE=false

# Azure Blob Storage settings (only when STORAGE_TYPE=azure)
AZURE_ACCOUNT_NAME=
AZURE_ACCOUNT_KEY=
AZURE_CONTAINER_NAME=

# --- Redis -------------------------------------------------------------------
# Built-in Redis password (required when using the bundled redis service).
REDIS_PASSWORD=
# Redis URL for multi-instance WebSocket pub/sub.
# Keep this in sync with REDIS_PASSWORD above.
# Example: redis://:<password>@redis:6379
REDIS_URL=

# --- API port (internal) ----------------------------------------------------
# The port the Fastify server listens on inside the container.
# Nginx connects to this; it is NOT exposed to the host.
API_PORT=3001

# --- Backups -----------------------------------------------------------------
# Host directory where backup archives/logs are stored.
# You can point this to another disk, e.g. /data/qlicker2/backups
BACKUP_HOST_PATH=./backups

# Backup manager polling interval in seconds.
BACKUP_CHECK_INTERVAL_SECONDS=60

# Optional timezone override for the backup manager container.
# Set this to the deployment's local timezone if it differs from UTC.
TZ=UTC

# --- Misc --------------------------------------------------------------------
NODE_ENV=production
ROOT_URL=https://${DOMAIN}
# Keep the Swagger/OpenAPI UI disabled on internet-facing deployments unless
# you explicitly need it for operational troubleshooting.
ENABLE_API_DOCS=false
